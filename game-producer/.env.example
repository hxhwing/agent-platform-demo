# Copy to .env and fill in your own values.  (.env is gitignored.)
# Game Producer (main multi-agent studio).
# NOTE: Gemini 3 models only resolve in location=global. agent.py also forces
# these in code; kept here for local clarity / overrides.
GOOGLE_GENAI_USE_VERTEXAI=TRUE
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=global

# External A2A localization studio (local server now; Cloud Run URL after deploy).
# The scaffolded localization-studio serves its card at /a2a/app/.well-known/agent-card.json
LOCALIZATION_AGENT_URL=http://localhost:8000
