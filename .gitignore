# ─── Secrets & local config (never commit) ───────────────────────────
# .env files hold the real GCP project id and local overrides.
.env
**/.env
*.env
!*.env.example

# Claude Code working files (local settings hold real deployment URLs / project numbers).
.claude/

# Terraform local vars that may hold a real project id.
**/vars/my_env.tfvars
*.tfvars.local

# ─── Runtime / session artifacts ─────────────────────────────────────
.adk/
**/.adk/

# ─── Python caches & envs ────────────────────────────────────────────
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
.mypy_cache/
.venv/
venv/
env/
*.egg-info/

# ─── Terraform state ─────────────────────────────────────────────────
**/.terraform/
*.tfstate
*.tfstate.*

# ─── OS / editor cruft ───────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
